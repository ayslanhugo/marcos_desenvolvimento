<!DOCTYPE html>
<html lang="pt-BR">
  <head>
    <title><%= content_for(:title) || "Marcos do Desenvolvimento" %></title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>
    
    <script>
      (function() {
        const theme = localStorage.getItem('theme');
        if (theme === 'dark' || (!theme && window.matchMedia('(prefers-color-scheme: dark)').matches)) {
          document.documentElement.classList.add('dark');
        } else {
          document.documentElement.classList.remove('dark');
        }
      })();
    </script>

    <meta name="mobile-web-app-capable" content="yes">
    <meta name="apple-mobile-web-app-capable" content="yes">
    <%= tag.link rel: "manifest", href: pwa_manifest_path(format: :json) %>
    
    <%= yield :head %>

    <link rel="icon" href="/icon.png?v=3" type="image/png">
    <link rel="apple-touch-icon" href="/icon.png?v=3">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/driver.js@1.3.1/dist/driver.css"/>

    <%= stylesheet_link_tag "application", "data-turbo-track": "reload" %>
    <%= javascript_include_tag "application", "data-turbo-track": "reload", type: "module" %>
  </head>

    <body data-controller="theme tour" class="bg-gray-50 text-gray-900 dark:bg-gray-950 dark:text-gray-100 font-sans transition-colors duration-300">
    
    <nav class="bg-white dark:bg-gray-900 border-b border-gray-200 dark:border-gray-800 shadow-sm relative z-40 mb-6 transition-colors">
      <div class="container mx-auto px-4 py-4 flex justify-between items-center">
        
        <%# LOGO %>
        <%= link_to "Marcos do Desenvolvimento", root_path, class: "text-sm sm:text-lg md:text-xl font-bold text-blue-600 dark:text-blue-400 shrink-0" %>
        
        <%# LADO DIREITO (Links + Botões) %>
        <div class="flex items-center gap-2 md:gap-4">
          
          <%# LINKS DESKTOP %>
          <div class="hidden lg:flex items-center gap-4 xl:gap-6 text-sm font-medium">
            <%# AQUI ENTRA O ID DO APRENDA %>
            <%= link_to "Aprenda", learn_path, id: "passo-aprenda", class: "text-gray-600 dark:text-gray-300 hover:text-blue-600 transition whitespace-nowrap" %>
            <%= link_to "FAQ", faq_path, class: "text-gray-600 dark:text-gray-300 hover:text-blue-600 transition whitespace-nowrap" %>
            <%= link_to "Rede de Apoio", support_path, class: "text-gray-600 dark:text-gray-300 hover:text-blue-600 transition whitespace-nowrap" %>
            
            <% if user_signed_in? %>
              <span class="text-gray-300 dark:text-gray-700">|</span>
              <%= link_to "Meus Pequenos", children_path, class: "text-blue-600 dark:text-blue-400 font-bold transition whitespace-nowrap" %>
              
              <span class="text-gray-300 dark:text-gray-700">|</span>
              <%= link_to "Meu Perfil", edit_user_registration_path, class: "text-gray-600 dark:text-gray-300 hover:text-blue-600 transition whitespace-nowrap" %>
              
              <% if current_user&.admin? %>
                <span class="text-gray-300 dark:text-gray-700">|</span>
                <%= link_to "Painel Admin", admin_root_path, class: "text-purple-600 dark:text-purple-400 font-black tracking-wide hover:text-purple-800 dark:hover:text-purple-300 transition-colors flex items-center gap-1 whitespace-nowrap" %>
              <% end %>
              
              <span class="text-gray-300 dark:text-gray-700">|</span>
              <%= button_to "Sair", destroy_user_session_path, method: :delete, class: "text-red-500 hover:text-red-700 transition whitespace-nowrap" %>

              <%# NOVO BOTÃO: REFAZER TUTORIAL %>
              <span class="text-gray-300 dark:text-gray-700">|</span>
              <button data-action="click->tour#reiniciar" class="flex items-center text-gray-400 hover:text-blue-600 transition whitespace-nowrap cursor-pointer" title="Refazer Tutorial">
                <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" class="w-5 h-5">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M9.879 7.519c1.171-1.025 3.071-1.025 4.242 0 1.172 1.025 1.172 2.687 0 3.712-.203.179-.43.326-.67.442-.745.361-1.45.999-1.45 1.827v.75M21 12a9 9 0 11-18 0 9 9 0 0118 0zm-9 5.25h.008v.008H12v-.008z" />
                </svg>
              </button>
            <% else %>
              <span class="text-gray-300 dark:text-gray-700">|</span>
              <%= link_to "Entrar", new_user_session_path, class: "text-blue-600 dark:text-blue-400 font-bold whitespace-nowrap" %>
            <% end %>
          </div>

          <%# BOTÃO MODO NOTURNO (Fora do grupo dos links, mas dentro do lado direito) %>
          <button data-action="click->theme#toggle" class="p-2 ml-2 rounded-xl bg-gray-100 dark:bg-gray-800 text-gray-600 dark:text-yellow-400 hover:ring-2 hover:ring-blue-300 transition-all focus:outline-none cursor-pointer" aria-label="Alternar modo noturno">
            <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 hidden dark:block" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 3v2.25m6.364.386l-1.591 1.591M21 12h-2.25m-.386 6.364l-1.591-1.591M12 18.75V21m-4.773-4.227l-1.591 1.591M5.25 12H3m4.227-4.773L5.636 5.636M15.75 12a3.75 3.75 0 11-7.5 0 3.75 3.75 0 017.5 0z" />
            </svg>
            <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 block dark:hidden" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M20.354 15.354A9 9 0 018.646 3.646 9.003 9.003 0 0012 21a9.003 9.003 0 008.354-5.646z" />
            </svg>
          </button>

          <%# MENU MOBILE %>
          <button id="mobile-menu-button" class="lg:hidden p-2 text-gray-600 dark:text-gray-300 hover:text-blue-600 focus:outline-none focus:ring-2 focus:ring-blue-300 rounded-lg transition" aria-label="Abrir menu">
            <svg xmlns="http://www.w3.org/2000/svg" class="h-7 w-7" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16" /></svg>
          </button>
        </div>
      </div>

      <div id="mobile-menu" class="hidden lg:hidden bg-gray-50 dark:bg-gray-900 border-t border-gray-100 dark:border-gray-800 px-4 pt-2 pb-4 space-y-3 font-medium shadow-inner">
        <%= link_to "Aprenda", learn_path, class: "block py-2 text-gray-700 dark:text-gray-300 hover:text-blue-600" %>
        <%= link_to "FAQ", faq_path, class: "block py-2 text-gray-700 dark:text-gray-300 hover:text-blue-600" %>
        <%= link_to "Rede de Apoio", support_path, class: "block py-2 text-gray-700 dark:text-gray-300 hover:text-blue-600" %>
        <% if user_signed_in? %>
          <%= link_to "Meus Pequenos", children_path, class: "block py-2 text-blue-600 dark:text-blue-400 font-bold" %>
          <div class="border-t border-gray-200 dark:border-gray-800 my-2 pt-2"></div>
          <%= link_to "Meu Perfil", edit_user_registration_path, class: "block py-2 text-gray-700 dark:text-gray-300 hover:text-blue-600" %>
          <% if current_user&.admin? %>
            <%= link_to "Painel Admin", admin_root_path, class: "block py-2 text-purple-600 dark:text-purple-400 font-bold" %>
          <% end %>
          
          <button data-action="click->tour#reiniciar" class="w-full text-left py-2 text-gray-700 dark:text-gray-300 hover:text-blue-600 font-medium">Refazer Tutorial</button>
          
          <%= button_to "Sair", destroy_user_session_path, method: :delete, class: "block w-full text-left py-2 text-red-500 hover:text-red-700", form_class: "w-full" %>
        <% else %>
          <%= link_to "Entrar", new_user_session_path, class: "block py-2 text-blue-600 dark:text-blue-400 font-bold" %>
        <% end %>
      </div>
    </nav>

    <div id="flash-messages" class="fixed top-5 right-5 z-50 flex flex-col gap-3 pointer-events-none">
      <% flash.each do |type, message| %>
        <% 
          if type == "notice" || type == "success"
            cores = "bg-white dark:bg-gray-800 border border-green-100 dark:border-green-900 text-gray-700 dark:text-gray-200 shadow-lg"
            icone = '<svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6 text-green-500" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z" /></svg>'
          else
            cores = "bg-white dark:bg-gray-800 border border-red-100 dark:border-red-900 text-gray-700 dark:text-gray-200 shadow-lg"
            icone = '<svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6 text-red-500" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4m0 4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z" /></svg>'
          end
        %>
        <div class="toast-message pointer-events-auto flex items-start p-4 rounded-2xl w-80 md:w-96 transform transition-all duration-500 translate-x-0 <%= cores %>">
          <div class="shrink-0 mr-3"><%= raw icone %></div>
          <div class="flex-1 text-sm font-medium pt-0.5 leading-relaxed"><%= message %></div>
          <button onclick="this.parentElement.style.display='none'" class="ml-4 shrink-0 text-gray-400 hover:text-gray-600 transition focus:outline-none cursor-pointer">
            <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" /></svg>
          </button>
        </div>
      <% end %>
    </div>

    <main>
      <%= yield %>
    </main>

    <script>
      // O Javascript nativo fica apenas para o Menu Mobile e Toasts
      document.addEventListener("turbo:load", function() {
        // Toggle do Menu Mobile
        const btn = document.getElementById('mobile-menu-button');
        const menu = document.getElementById('mobile-menu');
        if(btn && menu) {
          btn.replaceWith(btn.cloneNode(true));
          document.getElementById('mobile-menu-button').addEventListener('click', () => menu.classList.toggle('hidden'));
        }

        // Esconder Toasts automaticamente
        setTimeout(function() {
          document.querySelectorAll('.toast-message').forEach(function(toast) {
            toast.style.opacity = '0';
            toast.style.transform = 'translateY(-10px)';
            setTimeout(() => toast.remove(), 500); 
          });
        }, 5000); 
      });
    </script>
  </body>
</html>