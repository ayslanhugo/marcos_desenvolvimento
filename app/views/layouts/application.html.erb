<!DOCTYPE html>
<html>
  <head>
    <title><%= content_for(:title) || "Marcos do Desenvolvimento" %></title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>
    <meta name="mobile-web-app-capable" content="yes">
    <meta name="apple-mobile-web-app-capable" content="yes">
    
    <%= tag.link rel: "manifest", href: pwa_manifest_path(format: :json) %>
    <link rel="apple-touch-icon" href="/icon.png">

    <%= yield :head %>

    <link rel="icon" href="/icon.png" type="image/png">
    <link rel="icon" href="/icon.svg" type="image/svg+xml">
    <link rel="apple-touch-icon" href="/icon.png">

    <%= stylesheet_link_tag "application", "data-turbo-track": "reload" %>
    <%= javascript_include_tag "application", "data-turbo-track": "reload", type: "module" %>
  </head>

  <body class="bg-gray-50 text-gray-900 font-sans">
    
    <nav class="bg-white border-b border-gray-200 shadow-sm relative z-40 mb-6">
      <div class="container mx-auto px-4 py-4 flex justify-between items-center">
        <%= link_to "Marcos do Desenvolvimento", root_path, class: "text-sm sm:text-lg md:text-xl font-bold text-blue-600 shrink-0" %>
        
        <button id="mobile-menu-button" class="md:hidden p-2 text-gray-600 hover:text-blue-600 focus:outline-none focus:ring-2 focus:ring-blue-300 rounded-lg transition" aria-label="Abrir menu">
          <svg xmlns="http://www.w3.org/2000/svg" class="h-7 w-7" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16" />
          </svg>
        </button>

        <div class="hidden md:flex md:space-x-6 md:items-center text-sm md:text-base font-medium">
          <% if user_signed_in? %>
            <%= link_to "Aprenda", learn_path, class: "text-gray-600 hover:text-blue-600 transition" %>
            <%= link_to "Rede de Apoio", support_path, class: "text-gray-600 hover:text-blue-600 transition" %>
            <%= link_to "Meus Pequenos", children_path, class: "text-blue-600 font-bold transition" %>
            <span class="text-gray-300">|</span>
            <%= link_to "Meu Perfil", edit_user_registration_path, class: "text-gray-600 hover:text-blue-600 transition" %>
            <%= button_to "Sair", destroy_user_session_path, method: :delete, class: "text-red-500 hover:text-red-700 transition" %>
          <% else %>
            <%= link_to "Aprenda", learn_path, class: "text-gray-600 hover:text-blue-600 transition" %>
            <%= link_to "Entrar", new_user_session_path, class: "text-blue-600 font-bold" %>
          <% end %>
        </div>
      </div>

      <div id="mobile-menu" class="hidden md:hidden bg-gray-50 border-t border-gray-100 px-4 pt-2 pb-4 space-y-3 font-medium shadow-inner">
        <% if user_signed_in? %>
          <%= link_to "Aprenda", learn_path, class: "block py-2 text-gray-700 hover:text-blue-600" %>
          <%= link_to "Rede de Apoio", support_path, class: "block py-2 text-gray-700 hover:text-blue-600" %>
          <%= link_to "Meus Pequenos", children_path, class: "block py-2 text-blue-600 font-bold" %>
          <div class="border-t border-gray-200 my-2 pt-2"></div>
          <%= link_to "Meu Perfil", edit_user_registration_path, class: "block py-2 text-gray-700 hover:text-blue-600" %>
          <%= button_to "Sair", destroy_user_session_path, method: :delete, class: "block w-full text-left py-2 text-red-500 hover:text-red-700", form_class: "w-full" %>
        <% else %>
          <%= link_to "Aprenda", learn_path, class: "block py-2 text-gray-700 hover:text-blue-600" %>
          <%= link_to "Entrar", new_user_session_path, class: "block py-2 text-blue-600 font-bold" %>
        <% end %>
      </div>
    </nav>

    <script>
      document.addEventListener("turbo:load", function() {
        const btn = document.getElementById('mobile-menu-button');
        const menu = document.getElementById('mobile-menu');
        
        if(btn && menu) {
          btn.replaceWith(btn.cloneNode(true));
          const newBtn = document.getElementById('mobile-menu-button');
          newBtn.addEventListener('click', function() {
            menu.classList.toggle('hidden');
          });
        }
      });
    </script>

    <div id="flash-messages" class="fixed top-5 right-5 z-50 flex flex-col gap-3 pointer-events-none">
      <% flash.each do |type, message| %>
        <% 
          if type == "notice" || type == "success"
            cores = "bg-white border border-green-100 text-gray-700 shadow-lg shadow-green-900/5"
            icone = '<svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6 text-green-500" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z" /></svg>'
          else
            cores = "bg-white border border-red-100 text-gray-700 shadow-lg shadow-red-900/5"
            icone = '<svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6 text-red-500" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4m0 4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z" /></svg>'
          end
        %>
        
        <div class="toast-message pointer-events-auto flex items-start p-4 border rounded-2xl w-80 md:w-96 transform transition-all duration-500 translate-x-0 <%= cores %>">
          <div class="shrink-0 mr-3"> <%= raw icone %>
          </div>
          <div class="flex-1 text-sm font-medium pt-0.5 leading-relaxed">
            <%= message %>
          </div>
          <button onclick="this.parentElement.style.display='none'" class="ml-4 shrink-0 text-gray-400 hover:text-gray-600 transition focus:outline-none cursor-pointer"> <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" /></svg>
          </button>
        </div>
      <% end %>
    </div>

    <script>
      document.addEventListener("turbo:load", function() {
        setTimeout(function() {
          let toasts = document.querySelectorAll('.toast-message');
          toasts.forEach(function(toast) {
            toast.style.opacity = '0';
            toast.style.transform = 'translateY(-10px)';
            setTimeout(() => toast.remove(), 500); 
          });
        }, 5000); 
      });
    </script>

    <main>
      <%= yield %>
    </main>
  </body>
</html>