<div class="min-h-[80vh] flex items-center justify-center px-4">
  <div class="max-w-md w-full bg-white dark:bg-gray-900 rounded-3xl shadow-xl border border-gray-100 dark:border-gray-800 p-8">
    <div class="text-center mb-8">
      <h2 class="text-2xl font-black text-gray-900 dark:text-white">Criar Nova Senha</h2>
      <p class="text-gray-500 dark:text-gray-400 mt-2 text-sm">Quase lá! Crie uma senha forte e segura para a sua conta.</p>
    </div>

    <%= form_for(resource, as: resource_name, url: password_path(resource_name), html: { method: :put, class: "space-y-6" }) do |f| %>
      <%= render "devise/shared/error_messages", resource: resource %>
      <%= f.hidden_field :reset_password_token %>

      <div>
        <%= f.label :password, "Sua nova senha", class: "block text-sm font-bold text-gray-700 dark:text-gray-300 mb-2" %>
        <% if @minimum_password_length %>
          <span class="text-xs text-gray-500 dark:text-gray-400 block mb-2">(Mínimo de <%= @minimum_password_length %> caracteres)</span>
        <% end %>
        <%= f.password_field :password, autofocus: true, autocomplete: "new-password", class: "w-full px-4 py-3 rounded-xl border border-gray-300 dark:border-gray-700 bg-gray-50 dark:bg-gray-800 text-gray-900 dark:text-white focus:ring-2 focus:ring-blue-500 focus:border-blue-500 transition-colors", placeholder: "••••••••" %>
      </div>

      <div>
        <%= f.label :password_confirmation, "Confirme a nova senha", class: "block text-sm font-bold text-gray-700 dark:text-gray-300 mb-2" %>
        <%= f.password_field :password_confirmation, autocomplete: "new-password", class: "w-full px-4 py-3 rounded-xl border border-gray-300 dark:border-gray-700 bg-gray-50 dark:bg-gray-800 text-gray-900 dark:text-white focus:ring-2 focus:ring-blue-500 focus:border-blue-500 transition-colors", placeholder: "••••••••" %>
      </div>

      <div>
        <%= f.submit "Alterar minha senha", class: "w-full bg-green-600 hover:bg-green-700 text-white font-bold py-3 px-4 rounded-xl transition-colors shadow-sm hover:shadow-md cursor-pointer" %>
      </div>
    <% end %>

    <div class="mt-6 pt-6 border-t border-gray-100 dark:border-gray-800 text-center flex flex-col gap-3">
      <%= render "devise/shared/links" %>
    </div>
  </div>
</div>