<div class="max-w-md mx-auto mt-10 p-8 bg-white rounded-2xl shadow-sm border border-gray-100">
  <div class="mb-6">
    <%= link_to "← Voltar", children_path, class: "text-xs text-blue-600 font-bold hover:underline" %>
  </div>

  <h1 class="text-2xl font-bold text-blue-900 mb-2">Meu Perfil</h1>
  <p class="text-gray-600 mb-6 text-sm">Atualize seu e-mail ou troque sua senha de acesso.</p>

  <%= form_for(resource, as: resource_name, url: registration_path(resource_name), html: { method: :put, class: "space-y-4" }) do |f| %>
    <%= render "devise/shared/error_messages", resource: resource %>

    <div>
      <%= f.label :email, "E-mail de Acesso", class: "block text-sm font-medium text-gray-700" %>
      <%= f.email_field :email, autofocus: true, autocomplete: "email", class: "mt-1 block w-full rounded-md border-gray-300 shadow-sm focus:border-blue-500 focus:ring-blue-500" %>
    </div>

    <% if devise_mapping.confirmable? && resource.pending_reconfirmation? %>
      <div class="text-xs text-amber-600 bg-amber-50 p-2 rounded">
        Aguardando confirmação para: <%= resource.unconfirmed_email %>
      </div>
    <% end %>

    <div class="bg-gray-50 p-4 rounded-xl border border-gray-100 mt-6">
      <h3 class="text-sm font-bold text-gray-800 mb-3">Trocar Senha</h3>
      <p class="text-xs text-gray-500 mb-3">Deixe em branco se não quiser alterar.</p>
      
      <div class="space-y-3">
        <div>
          <%= f.label :password, "Nova Senha", class: "block text-xs font-medium text-gray-700" %>
          <%= f.password_field :password, autocomplete: "new-password", class: "mt-1 block w-full text-sm rounded-md border-gray-300 shadow-sm focus:border-blue-500 focus:ring-blue-500" %>
          <% if @minimum_password_length %>
            <em class="text-xs text-gray-500">Mínimo de <%= @minimum_password_length %> caracteres</em>
          <% end %>
        </div>

        <div>
          <%= f.label :password_confirmation, "Confirmar Nova Senha", class: "block text-xs font-medium text-gray-700" %>
          <%= f.password_field :password_confirmation, autocomplete: "new-password", class: "mt-1 block w-full text-sm rounded-md border-gray-300 shadow-sm focus:border-blue-500 focus:ring-blue-500" %>
        </div>
      </div>
    </div>

    <div class="bg-blue-50 p-4 rounded-xl border border-blue-100 mt-6 mb-6">
      <h3 class="text-sm font-bold text-blue-900 mb-2">Confirmação de Segurança</h3>
      <%= f.label :current_password, "Senha Atual", class: "block text-xs font-medium text-blue-800" %>
      <p class="text-xs text-blue-600 mb-2">Precisamos da sua senha atual para confirmar as mudanças.</p>
      <%= f.password_field :current_password, autocomplete: "current-password", class: "mt-1 block w-full text-sm rounded-md border-blue-300 shadow-sm focus:border-blue-500 focus:ring-blue-500" %>
    </div>

    <div class="pt-2">
      <%= f.submit "Salvar Alterações", class: "w-full bg-blue-600 text-white py-3 rounded-xl font-bold hover:bg-blue-700 transition cursor-pointer shadow-sm" %>
    </div>
  <% end %>

  <div class="mt-10 pt-6 border-t border-gray-100 text-center">
    <p class="text-sm text-gray-600 mb-3">Deseja encerrar sua conta?</p>
    <%= button_to "Excluir minha conta", registration_path(resource_name), data: { confirm: "Tem certeza? Isso apagará todos os dados.", turbo_confirm: "Tem certeza?" }, method: :delete, class: "text-red-500 hover:text-red-700 text-sm font-bold transition" %>
  </div>
</div>