<div class="max-w-2xl mx-auto mt-10 px-4 pb-20">
  <header class="mb-10 text-center">
    <h1 class="text-3xl font-extrabold text-blue-900 dark:text-blue-400 mb-2">Meu Perfil</h1>
    <p class="text-gray-600 dark:text-gray-400">Gerencie suas informações de acesso</p>
  </header>

  <div class="bg-white dark:bg-gray-900 p-8 rounded-3xl shadow-sm border border-gray-100 dark:border-gray-800 transition-colors">
    <%= form_for(resource, as: resource_name, url: registration_path(resource_name), html: { method: :put, class: "space-y-6" }) do |f| %>
      <%= render "devise/shared/error_messages", resource: resource %>

      <div>
        <%= f.label :email, "E-mail", class: "block text-sm font-bold text-gray-700 dark:text-gray-300 mb-2" %>
        <%= f.email_field :email, autofocus: true, autocomplete: "email", 
            class: "w-full px-4 py-3 rounded-2xl border border-gray-200 dark:border-gray-700 bg-gray-50 dark:bg-gray-800 text-gray-900 dark:text-white focus:ring-2 focus:ring-blue-500 transition-all outline-none" %>
      </div>

      <% if devise_mapping.confirmable? && resource.pending_reconfirmation? %>
        <div class="p-3 bg-yellow-50 dark:bg-yellow-900/20 text-yellow-700 dark:text-yellow-400 rounded-xl text-xs">
          Aguardando confirmação para: <%= resource.unconfirmed_email %>
        </div>
      <% end %>

      <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
        <div>
          <%= f.label :password, "Nova Senha", class: "block text-sm font-bold text-gray-700 dark:text-gray-300 mb-1" %>
          <i class="block text-[10px] text-gray-500 mb-2">(deixe em branco se não quiser alterar)</i>
          <%= f.password_field :password, autocomplete: "new-password", 
              class: "w-full px-4 py-3 rounded-2xl border border-gray-200 dark:border-gray-700 bg-gray-50 dark:bg-gray-800 text-gray-900 dark:text-white focus:ring-2 focus:ring-blue-500 transition-all outline-none" %>
        </div>

        <div>
          <%= f.label :password_confirmation, "Confirmar Nova Senha", class: "block text-sm font-bold text-gray-700 dark:text-gray-300 mb-1" %>
          <span class="block text-[10px] opacity-0 mb-2">placeholder</span>
          <%= f.password_field :password_confirmation, autocomplete: "new-password", 
              class: "w-full px-4 py-3 rounded-2xl border border-gray-200 dark:border-gray-700 bg-gray-50 dark:bg-gray-800 text-gray-900 dark:text-white focus:ring-2 focus:ring-blue-500 transition-all outline-none" %>
        </div>
      </div>

      <div class="pt-4 border-t border-gray-100 dark:border-gray-800">
        <%= f.label :current_password, "Senha Atual", class: "block text-sm font-bold text-gray-700 dark:text-gray-300 mb-1" %>
        <i class="block text-[10px] text-red-500 mb-2">(precisamos da sua senha atual para confirmar as mudanças)</i>
        <%= f.password_field :current_password, autocomplete: "current-password", 
            class: "w-full px-4 py-3 rounded-2xl border border-gray-200 dark:border-gray-700 bg-gray-50 dark:bg-gray-800 text-gray-900 dark:text-white focus:ring-2 focus:ring-blue-500 transition-all outline-none" %>
      </div>

      <div class="flex items-center justify-end gap-4 pt-4">
        <%= link_to "Voltar", :back, class: "text-sm font-bold text-gray-500 hover:text-gray-700 dark:hover:text-gray-300 transition-colors" %>
        <%= f.submit "Atualizar Perfil", class: "bg-blue-600 hover:bg-blue-700 text-white font-bold py-3 px-8 rounded-2xl transition-all shadow-lg shadow-blue-200 dark:shadow-none cursor-pointer hover:scale-105 active:scale-95 text-sm" %>
      </div>
    <% end %>
  </div>

  <% unless resource.email == "admin@master.com" %>
    <div class="mt-12 p-8 bg-red-50 dark:bg-red-900/10 border border-red-100 dark:border-red-900/30 rounded-3xl">
      <h3 class="text-red-800 dark:text-red-400 font-bold mb-2 text-sm uppercase tracking-widest">Zona de Perigo</h3>
      <p class="text-sm text-red-600 dark:text-red-300/70 mb-6 leading-relaxed">
        Uma vez excluída, sua conta e todos os dados das crianças vinculadas a este perfil não poderão ser recuperados.
      </p>
      <%= button_to "Excluir minha conta definitivamente", registration_path(resource_name), 
          data: { confirm: "Esta ação é irreversível. Tem certeza?", turbo_confirm: "Esta ação é irreversível. Tem certeza?" }, 
          method: :delete, 
          class: "text-sm font-black text-red-600 dark:text-red-500 hover:text-red-800 dark:hover:text-red-400 underline transition-colors cursor-pointer" %>
    </div>
  <% end %>
</div>