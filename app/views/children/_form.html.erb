<%= form_with(model: child, class: "space-y-6") do |f| %>
  <% if child.errors.any? %>
    <div class="p-4 bg-red-50 dark:bg-red-900/20 border border-red-200 dark:border-red-800/50 rounded-2xl">
      <h2 class="text-sm font-bold text-red-800 dark:text-red-400">Verifique os erros abaixo:</h2>
      <ul class="list-disc list-inside text-xs text-red-700 dark:text-red-300/80 mt-1">
        <% child.errors.full_messages.each do |message| %>
          <li><%= message %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <div>
    <%= f.label :nome, "Nome da Criança", class: "block text-sm font-bold text-gray-700 dark:text-gray-300 mb-2" %>
    <%= f.text_field :nome, placeholder: "Ex: Athos", 
        class: "w-full px-4 py-3 rounded-2xl border border-gray-200 dark:border-gray-700 bg-gray-50 dark:bg-gray-800 text-gray-900 dark:text-white placeholder-gray-400 dark:placeholder-gray-500 focus:ring-2 focus:ring-blue-500 outline-none transition-all" %>
  </div>

  <div>
    <%= f.label :data_nascimento, "Data de Nascimento", class: "block text-sm font-bold text-gray-700 dark:text-gray-300 mb-2" %>
    <%= f.date_field :data_nascimento, 
        class: "w-full px-4 py-3 rounded-2xl border border-gray-200 dark:border-gray-700 bg-gray-50 dark:bg-gray-800 text-gray-900 dark:text-white focus:ring-2 focus:ring-blue-500 outline-none transition-all" %>
  </div>

  <div class="bg-blue-50/50 dark:bg-blue-900/10 p-6 rounded-3xl border border-blue-100 dark:border-blue-900/30">
    <span class="block text-sm font-black text-blue-900 dark:text-blue-400 uppercase tracking-widest mb-4 italic">Perfil de Desenvolvimento</span>
    
    <div class="grid gap-4">
      <%# OPÇÃO: TÍPICO %>
      <label class="relative flex items-center p-4 bg-white dark:bg-gray-800 border-2 border-transparent has-checked:border-blue-500 rounded-2xl cursor-pointer shadow-sm transition-all hover:scale-[1.01]">
        <%= f.radio_button :tipo_desenvolvimento, "tipico", class: "peer sr-only" %>
        <div class="flex-1">
          <span class="block text-sm font-bold text-gray-900 dark:text-white">Desenvolvimento Típico</span>
          <span class="block text-xs text-gray-500 dark:text-gray-400">Marcos padrão (Papalia & Feldman)</span>
        </div>
        <div class="w-5 h-5 border-2 border-gray-300 dark:border-gray-600 rounded-full flex items-center justify-center peer-checked:border-blue-500 peer-checked:bg-blue-500 transition-all">
          <div class="w-2 h-2 bg-white rounded-full"></div>
        </div>
      </label>

      <%# OPÇÃO: DOWN %>
      <label class="relative flex items-center p-4 bg-white dark:bg-gray-800 border-2 border-transparent has-checked:border-blue-500 rounded-2xl cursor-pointer shadow-sm transition-all hover:scale-[1.01]">
        <%= f.radio_button :tipo_desenvolvimento, "sindrome_down", class: "peer sr-only" %>
        <div class="flex-1">
          <span class="block text-sm font-bold text-gray-900 dark:text-white">Síndrome de Down (T21)</span>
          <span class="block text-xs text-gray-500 dark:text-gray-400">Janelas de desenvolvimento adaptadas</span>
        </div>
        <div class="w-5 h-5 border-2 border-gray-300 dark:border-gray-600 rounded-full flex items-center justify-center peer-checked:border-blue-500 peer-checked:bg-blue-500 transition-all">
          <div class="w-2 h-2 bg-white rounded-full"></div>
        </div>
      </label>
    </div>
  </div>

  <div class="pt-4">
    <%= f.submit child.new_record? ? "Criar Perfil" : "Salvar Alterações", 
                 class: "w-full bg-blue-600 hover:bg-blue-700 dark:bg-blue-500 dark:hover:bg-blue-600 text-white py-4 rounded-2xl font-black uppercase tracking-widest transition-all cursor-pointer shadow-xl shadow-blue-200 dark:shadow-none hover:scale-[1.02] active:scale-95" %>
  </div>
<% end %>