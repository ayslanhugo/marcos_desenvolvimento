<%= form_with(model: child, class: "space-y-6") do |f| %>
  <% if child.errors.any? %>
    <div class="bg-red-50 p-4 rounded-lg border border-red-200">
      <h2 class="text-sm font-bold text-red-800">Verifique os erros abaixo:</h2>
      <ul class="list-disc list-inside text-xs text-red-700 mt-1">
        <% child.errors.full_messages.each do |message| %>
          <li><%= message %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <div>
    <%= f.label :nome, "Nome da Criança", class: "block text-sm font-medium text-gray-700" %>
    <%= f.text_field :nome, class: "mt-1 block w-full rounded-md border-gray-300 shadow-sm focus:border-blue-500 focus:ring-blue-500" %>
  </div>

  <div>
    <%= f.label :data_nascimento, "Data de Nascimento", class: "block text-sm font-medium text-gray-700" %>
    <%= f.date_field :data_nascimento, class: "mt-1 block w-full rounded-md border-gray-300 shadow-sm focus:border-blue-500 focus:ring-blue-500" %>
  </div>

  <div class="bg-blue-50 p-4 rounded-xl">
    <span class="block text-sm font-semibold text-blue-900 mb-3">Perfil de Desenvolvimento</span>
    <div class="flex flex-col gap-3">
      <label class="flex items-center gap-2 cursor-pointer">
        <%= f.radio_button :tipo_desenvolvimento, "tipico", class: "text-blue-600" %>
        <span class="text-sm text-gray-700 font-medium">Desenvolvimento Típico</span>
      </label>
      <label class="flex items-center gap-2 cursor-pointer">
        <%= f.radio_button :tipo_desenvolvimento, "sindrome_down", class: "text-blue-600" %>
        <span class="text-sm text-gray-700 font-medium">Síndrome de Down (Desenvolvimento Atípico)</span>
      </label>
    </div>
  </div>

  <div class="pt-4">
    <%= f.submit child.new_record? ? "Criar Perfil" : "Salvar Alterações", 
                 class: "w-full bg-blue-600 text-white py-3 rounded-xl font-bold hover:bg-blue-700 transition cursor-pointer shadow-lg shadow-blue-100" %>
  </div>
<% end %>