<div class="max-w-4xl mx-auto mt-6 md:mt-10 px-4 pb-20 transition-colors duration-300">
  
  <header class="flex flex-col md:flex-row justify-between items-start md:items-center mb-10 gap-4">
    <div>
      <h1 class="text-3xl md:text-4xl font-extrabold text-blue-900 dark:text-blue-400 tracking-tight">Meus Pequenos</h1>
      <p class="text-gray-600 dark:text-gray-400 mt-2">
        Você está acompanhando o desenvolvimento de <span class="font-bold text-gray-900 dark:text-gray-100"><%= current_user.children.count %> <%= "criança".pluralize(current_user.children.count) %></span>.
      </p>
    </div>
    
    <%= link_to new_child_path, id: "passo1-cadastrar", class: "group relative inline-flex items-center justify-center px-6 py-3 font-bold text-white bg-blue-600 dark:bg-blue-500 rounded-xl overflow-hidden shadow-lg hover:shadow-blue-500/30 transition-all hover:scale-105" do %>
      <span class="absolute w-0 h-0 transition-all duration-500 ease-out bg-white rounded-full group-hover:w-56 group-hover:h-56 opacity-10"></span>
      <span class="relative flex items-center">
        <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 mr-2" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M12 4v16m8-8H4" /></svg>
        Cadastrar Criança
      </span>
    <% end %>
  </header>

  <% if current_user.children.empty? %>
    <div class="text-center py-20 bg-white dark:bg-gray-900 rounded-3xl border-2 border-dashed border-gray-200 dark:border-gray-700 shadow-sm transition-colors">
      <div class="bg-blue-50 dark:bg-blue-900/20 w-20 h-20 rounded-full flex items-center justify-center mx-auto mb-6">
        <svg xmlns="http://www.w3.org/2000/svg" class="h-10 w-10 text-blue-500 dark:text-blue-400" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14.828 14.828a4 4 0 01-5.656 0M9 10h.01M15 10h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
        </svg>
      </div>
      <h3 class="text-xl font-bold text-gray-800 dark:text-gray-100 mb-2">Nenhuma criança cadastrada</h3>
      <p class="text-gray-500 dark:text-gray-400 max-w-sm mx-auto mb-8">Comece agora a registrar e acompanhar de perto os marcos de desenvolvimento.</p>
      <%= link_to "Adicionar meu primeiro filho", new_child_path, class: "font-bold text-blue-600 dark:text-blue-400 hover:text-blue-800 dark:hover:text-blue-300 hover:underline" %>
    </div>
  <% else %>
    
    <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
      <% current_user.children.each do |child| %>
        
        <% 
          # Lógica para Avatares Coloridos (Gera uma cor baseada no tamanho do nome)
          inicial = child.nome.first.upcase rescue "?"
          cores = [
            "bg-blue-100 text-blue-700 dark:bg-blue-900/40 dark:text-blue-400",
            "bg-emerald-100 text-emerald-700 dark:bg-emerald-900/40 dark:text-emerald-400",
            "bg-purple-100 text-purple-700 dark:bg-purple-900/40 dark:text-purple-400",
            "bg-orange-100 text-orange-700 dark:bg-orange-900/40 dark:text-orange-400",
            "bg-pink-100 text-pink-700 dark:bg-pink-900/40 dark:text-pink-400"
          ]
          cor_avatar = cores[child.nome.to_s.length % cores.size] 
        %>

        <div class="bg-white dark:bg-gray-900 rounded-3xl p-6 shadow-sm hover:shadow-md transition-shadow border border-gray-100 dark:border-gray-800 relative overflow-hidden group">
          
          <div class="flex justify-between items-start mb-6">
            <div class="flex items-center gap-4">
              <div class="h-14 w-14 rounded-full flex items-center justify-center text-2xl font-black shrink-0 <%= cor_avatar %>">
                <%= inicial %>
              </div>
              <div>
                <h2 class="text-2xl font-black text-gray-800 dark:text-gray-100 capitalize"><%= child.nome %></h2>
                <span class="inline-block mt-1 px-2.5 py-1 bg-green-50 dark:bg-green-900/20 text-green-600 dark:text-green-400 text-[10px] font-black uppercase tracking-wider rounded-full border border-green-100 dark:border-green-800/30">
                  <%= child.tipo_desenvolvimento.humanize %>
                </span>
              </div>
            </div>
          </div>

          <div class="space-y-2 mb-6 ml-1">
            <p class="text-sm text-gray-500 dark:text-gray-400 flex items-center gap-2">
              <span>📅</span> Nasc: <strong class="text-gray-900 dark:text-gray-200"><%= child.data_nascimento.strftime("%d/%m/%Y") %></strong>
            </p>
            <p class="text-sm text-gray-500 dark:text-gray-400 flex items-center gap-2">
              <span>⏳</span> Idade: <strong class="text-gray-900 dark:text-gray-200"><%= child.idade_em_meses %> meses</strong>
            </p>
          </div>

          <div class="flex gap-2 mt-auto">
            <%= link_to "Ver Marcos", child_path(child), id: ("passo2-marcos" if child == current_user.children.first), class: "flex-1 bg-blue-50 dark:bg-blue-900/20 text-blue-700 dark:text-blue-400 font-bold py-3 px-4 rounded-xl text-center hover:bg-blue-100 dark:hover:bg-blue-900/40 transition-colors" %>
            
            <%= link_to edit_child_path(child), class: "p-3 bg-white dark:bg-gray-800 border border-gray-200 dark:border-gray-700 rounded-xl text-gray-400 hover:text-blue-600 dark:hover:text-blue-400 transition hover:bg-gray-50 dark:hover:bg-gray-700" do %>
              <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15.232 5.232l3.536 3.536m-2.036-5.036a2.5 2.5 0 113.536 3.536L6.5 21.036H3v-3.572L16.732 3.732z" /></svg>
            <% end %>

            <%= button_to child_path(child), method: :delete, form: { data: { turbo_confirm: "Tem certeza que deseja excluir o perfil de #{child.nome}?" } }, class: "p-3 bg-white dark:bg-gray-800 border border-gray-200 dark:border-gray-700 rounded-xl text-gray-400 hover:text-red-600 dark:hover:text-red-400 transition hover:bg-red-50 dark:hover:bg-red-900/20 cursor-pointer" do %>
              <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16" /></svg>
            <% end %>
          </div>
          
        </div>
      <% end %>
    </div>
  <% end %>
</div>