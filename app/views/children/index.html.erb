<div class="max-w-5xl mx-auto mt-8 md:mt-12 px-4 pb-20">
  
  <header class="flex flex-col md:flex-row justify-between items-start md:items-center mb-10 gap-4">
    <div>
      <h1 class="text-3xl font-extrabold text-blue-900" tabindex="0">Meus Pequenos</h1>
      <p class="text-gray-600 mt-2 text-sm md:text-base">
        <% if @children.any? %>
          Você está acompanhando o desenvolvimento de <strong><%= pluralize(@children.count, 'criança', 'crianças') %></strong>.
        <% else %>
          Cadastre seu primeiro pequeno para começar.
        <% end %>
      </p>
    </div>
    
    <%= link_to new_child_path, class: "w-full md:w-auto text-center bg-blue-600 text-white px-6 py-3 rounded-xl font-bold hover:bg-blue-700 transition shadow-lg shadow-blue-200 focus:ring-4 focus:ring-blue-300 focus:outline-none", aria: { label: "Cadastrar nova criança" } do %>
      <span aria-hidden="true" class="mr-2">+</span> Cadastrar Criança
    <% end %>
  </header>

  <% if @children.any? %>
    
    <div class="grid grid-cols-1 md:grid-cols-2 gap-6 md:gap-8" role="list" aria-label="Lista de crianças cadastradas">
      <% @children.each do |child| %>
        
        <article class="bg-white p-6 md:p-8 rounded-3xl shadow-sm border border-gray-100 hover:shadow-lg transition-shadow duration-300 relative" role="listitem">
          
          <div class="flex items-center justify-between mb-4">
            <h2 class="text-2xl font-bold text-gray-800" tabindex="0"><%= child.nome %></h2>
            <span class="px-3 py-1 text-xs font-bold rounded-full <%= child.tipico? ? 'bg-green-100 text-green-800' : 'bg-purple-100 text-purple-800' %>" aria-label="Perfil: <%= child.tipo_desenvolvimento.humanize %>">
              <%= child.tipo_desenvolvimento.humanize %>
            </span>
          </div>

          <div class="text-gray-600 text-sm mb-6 space-y-2">
            <p><span class="sr-only">Data de nascimento:</span> 📅 <%= child.data_nascimento.strftime("%d/%m/%Y") %></p>
            <p><span class="sr-only">Idade atual:</span> ⏳ <strong><%= child.idade_em_meses %> meses</strong></p>
          </div>
          
          <div class="flex flex-col sm:flex-row items-center gap-3 mt-4 border-t border-gray-50 pt-6">
            <%= link_to child_path(child), class: "w-full sm:flex-1 text-center bg-blue-50 text-blue-700 py-3 rounded-xl font-bold hover:bg-blue-600 hover:text-white transition focus:ring-4 focus:ring-blue-300 focus:outline-none" do %>
              Ver Marcos
              <span class="sr-only">de <%= child.nome %></span>
            <% end %>

            <div class="flex w-full sm:w-auto gap-2">
              <%= link_to edit_child_path(child), class: "flex-1 sm:flex-none flex justify-center items-center p-3 border border-gray-200 text-gray-400 rounded-xl hover:text-blue-600 hover:bg-blue-50 transition focus:ring-2 focus:ring-blue-300 focus:outline-none", aria: { label: "Editar perfil de #{child.nome}" } do %>
                <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15.232 5.232l3.536 3.536m-2.036-5.036a2.5 2.5 0 113.536 3.536L6.5 21.036H3v-3.572L16.732 3.732z" />
                </svg>
              <% end %>

              <%= button_to child_path(child), method: :delete, 
                            data: { turbo_confirm: "Tem certeza que deseja excluir o perfil de #{child.nome}?" }, 
                            class: "flex-1 sm:flex-none flex justify-center items-center p-3 border border-gray-200 text-gray-400 rounded-xl hover:text-red-600 hover:bg-red-50 transition focus:ring-2 focus:ring-red-300 focus:outline-none",
                            aria: { label: "Excluir perfil de #{child.nome}" } do %>
                <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16" />
                </svg>
              <% end %>
            </div>
          </div>
        </article>
      <% end %>
    </div>
  <% else %>
    
    <div class="text-center py-20 bg-white rounded-3xl border border-dashed border-gray-300 shadow-sm" role="status">
      <div class="mx-auto w-20 h-20 bg-gray-50 text-gray-300 rounded-full flex items-center justify-center mb-4">
        <svg xmlns="http://www.w3.org/2000/svg" class="h-10 w-10" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4" />
        </svg>
      </div>
      <h2 class="text-xl font-bold text-gray-700 mb-2">Nenhum pequeno por aqui ainda</h2>
      <p class="text-gray-500 mb-6 max-w-sm mx-auto">Adicione o perfil da criança para começar a acompanhar os marcos de desenvolvimento.</p>
      <%= link_to "Cadastrar agora", new_child_path, class: "inline-block bg-blue-100 text-blue-700 font-bold px-6 py-2 rounded-full hover:bg-blue-200 transition focus:ring-4 focus:ring-blue-300 focus:outline-none" %>
    </div>
  <% end %>
</div>