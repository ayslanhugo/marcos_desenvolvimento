<div class="max-w-4xl mx-auto p-4 md:p-10 bg-white min-h-screen">
  
  <%# BOTÕES DE AÇÃO - Não saem na impressão %>
  <div class="no-print mb-8 flex justify-between items-center border-b border-gray-100 pb-4">
    <%= link_to children_path, class: "text-gray-500 hover:text-blue-600 flex items-center gap-2 text-sm font-bold" do %>
      <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 19l-7-7m0 0l7-7m-7 7h18" />
      </svg>
      Voltar
    <% end %>
    <button onclick="window.print()" class="bg-blue-600 hover:bg-blue-700 text-white px-6 py-2 rounded-xl font-black text-sm uppercase tracking-widest transition shadow-lg shadow-blue-200">
      🖨️ Imprimir para o Pediatra
    </button>
  </div>

  <%# CABEÇALHO DO RELATÓRIO %>
  <div class="border-b-4 border-black pb-6 mb-8 flex justify-between items-start">
    <div>
      <h1 class="text-3xl font-black uppercase tracking-tighter text-gray-900 leading-none">Relatório de Vigilância do Desenvolvimento</h1>
      <p class="text-sm text-gray-600 mt-2 font-medium">Extraído via Plataforma Marcos do Desenvolvimento em <%= Time.current.strftime("%d/%m/%Y às %H:%M") %></p>
    </div>
    <div class="text-right">
      <span class="inline-block bg-black text-white text-[10px] px-2 py-1 font-black uppercase rounded">Documento de Apoio Clínico</span>
    </div>
  </div>

  <%# FICHA DO PACIENTE %>
  <div class="grid grid-cols-2 gap-4 mb-8 border-2 border-black rounded-2xl p-6 bg-gray-50">
    <div class="space-y-4">
      <div>
        <span class="font-black uppercase text-gray-400 text-[10px] block tracking-widest">Paciente</span>
        <span class="text-xl font-black text-black"><%= @child.nome %></span>
      </div>
      <div>
        <span class="font-black uppercase text-gray-400 text-[10px] block tracking-widest">Data de Nascimento</span>
        <span class="text-base font-bold text-gray-800"><%= @child.data_nascimento.strftime("%d/%m/%Y") %></span>
      </div>
    </div>
    <div class="space-y-4 border-l border-gray-200 pl-6">
      <div>
        <span class="font-black uppercase text-gray-400 text-[10px] block tracking-widest">Protocolo de Referência</span>
        <span class="text-lg font-black <%= @child.sindrome_down? ? 'text-purple-700' : 'text-blue-700' %>">
          <%= @child.sindrome_down? ? "Síndrome de Down (T21)" : "Desenvolvimento Típico" %>
        </span>
      </div>
      <div>
        <span class="font-black uppercase text-gray-400 text-[10px] block tracking-widest">Idade Cronológica</span>
        <span class="text-lg font-black text-black"><%= @child.idade_em_meses %> meses</span>
      </div>
    </div>
  </div>

  <%# ALERTAS DE SEGURANÇA (RED FLAGS) %>
  <% if @child.progresses.any?(&:red_flag?) %>
    <div class="border-4 border-red-600 bg-red-50 p-6 mb-10 rounded-2xl animate-pulse-slow">
      <h2 class="font-black text-red-700 uppercase mb-3 text-base flex items-center gap-2">
        <span>⚠️</span> ALERTA DE VIGILÂNCIA: REGRESSÃO DETECTADA
      </h2>
      <p class="text-sm text-red-800 mb-4 leading-relaxed font-medium">
        Os itens abaixo foram reportados como habilidades anteriormente adquiridas que sofreram perda ou interrupção. 
        Este sinal clínico requer avaliação prioritária do pediatra ou neurologista infantil.
      </p>
      <div class="grid grid-cols-1 md:grid-cols-2 gap-3">
        <% @child.progresses.select(&:red_flag?).each do |prog| %>
           <div class="bg-white border border-red-200 p-3 rounded-xl flex items-center gap-3 shadow-sm">
             <span class="w-2 h-2 bg-red-600 rounded-full"></span>
             <span class="text-sm font-bold text-red-900"><%= prog.milestone.titulo %></span>
           </div>
        <% end %>
      </div>
    </div>
  <% end %>

  <%# TABELA DE MARCOS %>
  <h2 class="text-xl font-black uppercase tracking-widest text-gray-900 mb-6 flex items-center gap-3">
    <span class="w-8 h-1 bg-black inline-block"></span>
    Histórico de Aquisições
  </h2>

  <div class="overflow-hidden border-2 border-black rounded-2xl mb-12">
    <table class="w-full text-sm text-left border-collapse">
      <thead>
        <tr class="bg-black text-white">
          <th class="p-4 w-[15%] font-black uppercase text-[10px] tracking-widest">Área</th>
          <th class="p-4 w-[30%] font-black uppercase text-[10px] tracking-widest text-center">Habilidade Analisada</th>
          <th class="p-4 w-[15%] font-black uppercase text-[10px] tracking-widest text-center">Janela (Meses)</th>
          <th class="p-4 w-[15%] font-black uppercase text-[10px] tracking-widest text-center">Status</th>
          <th class="p-4 w-[25%] font-black uppercase text-[10px] tracking-widest">Observações da Família</th>
        </tr>
      </thead>
      <tbody class="divide-y divide-gray-200">
        <% @milestones.each do |milestone| %>
          <% 
            progress = @progresses.find { |p| p.milestone_id == milestone.id }
            next unless progress
            
            status_style = case progress.status
                          when 'adquirido' then "bg-green-100 text-green-800"
                          when 'em_aquisicao' then "bg-blue-50 text-blue-800 border border-blue-200"
                          when 'regressao' then "bg-red-600 text-white font-black animate-pulse"
                          else "bg-gray-100 text-gray-500"
                          end
          %>
          <tr class="hover:bg-gray-50 transition-colors align-top">
            <td class="p-4 font-black text-gray-400 uppercase text-[10px]">
              <%= milestone.categoria.present? ? milestone.categoria.humanize : "Não Definida" %>
            </td>
            <td class="p-4">
              <p class="font-black text-gray-900 text-sm leading-tight mb-1"><%= milestone.titulo %></p>
              <p class="text-[11px] text-gray-500 leading-normal"><%= milestone.descricao %></p>
            </td>
            <td class="p-4 text-center font-bold text-gray-600 text-xs">
              <span class="bg-gray-200 px-2 py-1 rounded text-black"><%= milestone.idade_minima_meses %> - <%= milestone.idade_maxima_meses %></span>
            </td>
            <td class="p-4 text-center">
              <span class="inline-block px-3 py-1 rounded-full text-[10px] font-black uppercase <%= status_style %>">
                <% if progress.status == 'em_aquisicao' %>
                  Em Aquisição
                <% else %>
                  <%= progress.status.humanize %>
                <% end %>
              </span>
            </td>
            <td class="p-4 text-[11px] text-gray-700 italic leading-relaxed">
              <%= progress.notes.present? ? "“#{progress.notes}”" : "-" %>
            </td>
          </tr>
        <% end %>
      </tbody>
    </table>
  </div>

  <%# RODAPÉ TÉCNICO E ASSINATURA %>
  <div class="mt-20 pt-10 border-t-2 border-gray-200">
    <div class="grid grid-cols-2 gap-10 items-end">
      <div class="text-[9px] text-gray-400 font-medium leading-relaxed uppercase tracking-wider">
        <p class="font-black mb-1 text-gray-600 text-[10px]">Referências Científicas:</p>
        1. Papalia, D. E.; Feldman, R. D. Desenvolvimento Humano. 12ª Ed. Artmed.<br>
        <% if @child.sindrome_down? %>
          2. American Academy of Pediatrics (AAP) - Health Supervision for Children With Down Syndrome.<br>
          3. Centers for Disease Control and Prevention (CDC) - Developmental Milestones.
        <% end %>
        <p class="mt-3">Este relatório é uma ferramenta de triagem baseada no relato familiar e não substitui o diagnóstico clínico profissional.</p>
      </div>
      
      <div class="text-center">
        <div class="border-t-2 border-black w-full mb-2"></div>
        <p class="text-xs font-black text-gray-900 uppercase">Carimbo e Assinatura do Pediatra</p>
        <p class="text-[10px] text-gray-400 mt-1">Data: ____/____/________</p>
      </div>
    </div>
  </div>
</div>