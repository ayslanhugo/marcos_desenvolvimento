<%# app/views/children/_milestone_card.html.erb %>
<% 
  # Busca o progresso real ou constrói um temporário para o form
  progress = child.progresses.find_by(milestone: milestone) || child.progresses.build(milestone: milestone) 
  
  # Um marco só conta como "avaliado" se ele existe no banco E o status não é 'nao_avaliado'
  foi_avaliado = progress.persisted? && progress.status != "nao_avaliado"

  # Definição das cores do CARD
  card_classes = if foi_avaliado
    case progress.status
      when "adquirido" then "bg-green-50 dark:bg-green-900/10 border-green-200 dark:border-green-800/50 shadow-inner"
      when "em_aquisicao" then "bg-yellow-50 dark:bg-yellow-900/10 border-yellow-200 dark:border-yellow-800/50"
      when "regressao" then "bg-red-50 dark:bg-red-900/10 border-red-200 dark:border-red-800/50"
    end
  else
    # Estilo Neutro (Branco no Light / Cinza Escuro no Dark)
    "bg-white dark:bg-gray-900 border-gray-100 dark:border-gray-800 shadow-sm hover:shadow-md"
  end

  # Definição das cores da BADGE (o selinho de status)
  badge_classes = if foi_avaliado
    case progress.status
      when 'adquirido' then 'bg-green-100 text-green-700 dark:bg-green-900/40 dark:text-green-400'
      when 'em_aquisicao' then 'bg-yellow-100 text-yellow-700 dark:bg-yellow-900/40 dark:text-yellow-400'
      when 'regressao' then 'bg-red-100 text-red-700 dark:bg-red-900/40 dark:text-red-400'
    end
  else
    "hidden" # Esconde o selinho se não foi avaliado
  end
%>

<%= turbo_frame_tag dom_id(milestone) do %>
  <%# 1. O CARD VISÍVEL %>
  <div class="tour-alvo-marcar milestone-card relative p-6 rounded-3xl border-2 transition-all duration-300 flex flex-col cursor-pointer <%= card_classes %>" 
       onclick="document.getElementById('modal_milestone_<%= milestone.id %>').showModal()">
    
    <div class="flex justify-between items-start mb-2">
      <h3 class="font-bold text-gray-900 dark:text-gray-100 text-lg pr-12"><%= milestone.titulo %></h3>
      
      <%# Selinho de Status - Só aparece se foi_avaliado for true %>
      <span class="absolute top-4 right-4 text-[10px] font-black uppercase px-2.5 py-1 rounded-full <%= badge_classes %>">
        <%= progress.status.humanize if foi_avaliado %>
      </span>
    </div>
        
    <%# O alerta acolhedor mostra o aviso amarelo de "Atenção" apenas se a criança estiver atrasada cronologicamente %>
    <%= alerta_acolhedor(milestone, child) %>
    
    <p class="text-gray-600 dark:text-gray-400 text-sm leading-relaxed mt-2"><%= milestone.descricao %></p>

    <span class="inline-block mt-4 text-[10px] font-bold uppercase tracking-wider text-blue-500 dark:text-blue-400 bg-blue-50 dark:bg-blue-900/30 px-3 py-1 rounded-full border border-blue-100 dark:border-blue-800/50 self-start">
      Janela: <%= milestone.idade_minima_meses %> a <%= milestone.idade_maxima_meses %> meses
    </span>
  </div>

  <%# 2. O MODAL DE AVALIAÇÃO %>
  <dialog id="modal_milestone_<%= milestone.id %>" class="backdrop:bg-gray-900/80 p-0 rounded-4xl shadow-2xl bg-white dark:bg-gray-900 max-w-lg w-full mx-auto my-auto fixed open:animate-in open:fade-in open:zoom-in-95 duration-200 border-none">
    <div class="p-8">
      <div class="flex justify-between items-center mb-8">
        <div>
          <h3 class="text-2xl font-black text-gray-900 dark:text-white">Avaliar Marco</h3>
          <p class="text-sm text-gray-500 dark:text-gray-400">Como está o progresso de <%= child.nome %>?</p>
        </div>
        <button onclick="this.closest('dialog').close()" class="p-2 hover:bg-gray-100 dark:hover:bg-gray-800 rounded-full transition-colors text-gray-400 dark:text-gray-500">
          <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"></path></svg>
        </button>
      </div>

      <%= form_with(model: [child, progress], url: child_progresses_path(child), method: :post, class: "space-y-6") do |f| %>
        <%= f.hidden_field :milestone_id, value: milestone.id %>
        
        <div class="grid grid-cols-2 gap-4">
          <%# STATUS: NÃO AVALIADO %>
          <label class="relative flex flex-col p-4 border-2 border-gray-100 dark:border-gray-800 rounded-2xl cursor-pointer hover:border-blue-400 transition-all has-checked:border-blue-500 has-checked:bg-blue-50/30 dark:has-checked:bg-blue-900/20">
            <%= f.radio_button :status, "nao_avaliado", class: "peer sr-only" %>
            <span class="text-sm font-bold text-gray-900 dark:text-white">Não Avaliado</span>
            <div class="absolute top-2 right-2 opacity-0 peer-checked:opacity-100 text-blue-500 text-xs">●</div>
          </label>

          <%# STATUS: EM AQUISIÇÃO %>
          <label class="relative flex flex-col p-4 border-2 border-yellow-100 dark:border-yellow-900/30 rounded-2xl cursor-pointer hover:border-yellow-400 transition-all has-checked:border-yellow-500 has-checked:bg-yellow-50 dark:has-checked:bg-yellow-900/20">
            <%= f.radio_button :status, "em_aquisicao", class: "peer sr-only" %>
            <span class="text-sm font-bold text-yellow-700 dark:text-yellow-400">⏳ Em Aquisição</span>
            <div class="absolute top-2 right-2 opacity-0 peer-checked:opacity-100 text-yellow-500 text-xs">●</div>
          </label>

          <%# STATUS: ADQUIRIDO %>
          <label class="relative flex flex-col p-4 border-2 border-green-100 dark:border-green-900/30 rounded-2xl cursor-pointer hover:border-green-400 transition-all has-checked:border-green-500 has-checked:bg-green-50 dark:has-checked:bg-green-900/20">
            <%= f.radio_button :status, "adquirido", class: "peer sr-only" %>
            <span class="text-sm font-bold text-green-700 dark:text-green-400">✔️ Adquirido</span>
            <div class="absolute top-2 right-2 opacity-0 peer-checked:opacity-100 text-green-500 text-xs">●</div>
          </label>

          <%# STATUS: REGRESSÃO %>
          <label class="relative flex flex-col p-4 border-2 border-red-100 dark:border-red-900/30 rounded-2xl cursor-pointer hover:border-red-400 transition-all has-checked:border-red-500 has-checked:bg-red-50 dark:has-checked:bg-red-900/20">
            <%= f.radio_button :status, "regressao", class: "peer sr-only" %>
            <span class="text-sm font-bold text-red-700 dark:text-red-400">🚨 Regressão</span>
            <div class="absolute top-2 right-2 opacity-0 peer-checked:opacity-100 text-red-500 text-xs">●</div>
          </label>
        </div>

        <div>
          <label class="block text-sm font-bold text-gray-700 dark:text-gray-300 mb-2">Observações (Opcional)</label>
          <%= f.text_area :notes, rows: 3, placeholder: "Como ele se comportou?", class: "w-full px-4 py-3 rounded-2xl border border-gray-200 dark:border-gray-700 bg-gray-50 dark:bg-gray-800 text-gray-900 dark:text-white focus:ring-2 focus:ring-blue-500 transition-all resize-none text-sm" %>
        </div>

        <div class="pt-6 border-t border-gray-100 dark:border-gray-700 flex items-center justify-end gap-4">
          <button type="button" onclick="this.closest('dialog').close()" class="text-sm font-bold text-gray-500 cursor-pointer">Cancelar</button>
          <%= f.submit "Salvar Avaliação", 
              onclick: "setTimeout(() => { this.closest('dialog').close() }, 100)", 
              class: "bg-blue-600 hover:bg-blue-700 text-white font-bold py-3 px-8 rounded-2xl transition-all shadow-lg cursor-pointer text-sm" %>
        </div>
      <% end %>
    </div>
  </dialog>
<% end %>