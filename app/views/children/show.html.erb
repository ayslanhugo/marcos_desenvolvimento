<div class="max-w-4xl mx-auto mt-6 md:mt-10 px-4 pb-20 transition-colors duration-300">
  
  <style>
    @media print {
      nav, footer, .no-print, button, form, .timeline-nav, .dark-chart-bg { display: none !important; }
      body { background-color: white !important; color: black !important; }
      .bg-blue-600 { background-color: #2563eb !important; -webkit-print-color-adjust: exact; print-color-adjust: exact; }
      .bg-green-50 { background-color: #f0fdf4 !important; -webkit-print-color-adjust: exact; print-color-adjust: exact; }
      section, .milestone-card { page-break-inside: avoid; border: 1px solid #e5e7eb !important; background: white !important; }
      .shadow-sm, .shadow-xl, .shadow-inner { box-shadow: none !important; }
      h1, h2, h3, p, span { color: black !important; }
    }
  </style>

  <nav class="mb-8 no-print">
    <%= link_to "← Voltar para Meus Pequenos", children_path, class: "text-blue-600 dark:text-blue-400 hover:underline text-sm font-medium" %>
  </nav>

  <div class="no-print flex justify-end mb-6">
    <button onclick="window.print()" class="flex items-center bg-gray-800 dark:bg-blue-600 text-white px-5 py-2.5 rounded-xl text-sm font-bold hover:bg-black dark:hover:bg-blue-700 transition shadow-lg shadow-gray-200 dark:shadow-none cursor-pointer">
      <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 mr-2" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 17h2a2 2 0 002-2v-4a2 2 0 00-2-2H5a2 2 0 00-2 2v4a2 2 0 002 2h2m2 4h6a2 2 0 002-2v-4a2 2 0 00-2-2H9a2 2 0 00-2 2v4a2 2 0 002 2zm8-12V5a2 2 0 00-2-2H9a2 2 0 00-2 2v4h10z" /></svg>
      Gerar Relatório Médico
    </button>
  </div>

  <header class="mb-10 text-center">
    <h1 class="text-3xl md:text-4xl font-extrabold text-blue-900 dark:text-blue-400 mb-2">Marcos de <%= @child.nome %></h1>
    <p class="text-gray-600 dark:text-gray-400">
      Perfil: <span class="font-semibold"><%= @child.tipo_desenvolvimento.humanize %></span> • 
      Idade atual: <span class="font-semibold text-blue-700 dark:text-blue-500"><%= @child.idade_em_meses %> meses</span>
    </p>
  </header>
<% if @child.progresses.any?(&:red_flag?) %>
    <div class="mb-10 bg-red-50 dark:bg-red-900/20 border-l-4 border-red-500 p-6 rounded-r-3xl rounded-l-md shadow-sm no-print transition-colors duration-300">
      <div class="flex items-start">
        <div class="shrink-0 mt-0.5">
          <svg class="h-6 w-6 text-red-600 dark:text-red-400 animate-pulse" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z" />
          </svg>
        </div>
        <div class="ml-4">
          <h3 class="text-sm font-black text-red-800 dark:text-red-400 uppercase tracking-widest mb-2">Atenção ao Desenvolvimento</h3>
          <p class="text-sm text-red-700 dark:text-red-300 leading-relaxed">
            O nosso sistema de vigilância identificou que alguns marcos sinalizam possível atraso ou regressão. Não se preocupe, cada criança tem seu ritmo, mas é <strong>altamente recomendado</strong> clicar em "Gerar Relatório Médico" e levar estas anotações para o pediatra do(a) <%= @child.nome %>.
          </p>
        </div>
      </div>
    </div>
  <% end %>

  <div class="mb-10 bg-white dark:bg-gray-900 p-6 rounded-3xl shadow-sm border border-blue-50 dark:border-gray-800 transition-colors">
    <div class="flex justify-between items-end mb-3">
      <h3 class="text-xs font-bold text-blue-800 dark:text-blue-400 uppercase tracking-widest">Progresso Geral</h3>
      <span class="text-xs font-bold text-gray-500 dark:text-gray-400"><%= @achieved_milestones %> de <%= @total_milestones %> concluídos</span>
    </div>
    <div class="w-full bg-gray-100 dark:bg-gray-800 rounded-full h-4 overflow-hidden">
      <div class="bg-blue-600 dark:bg-blue-500 h-full transition-all duration-1000" style="width: <%= @percentage %>%"></div>
    </div>
    <p class="mt-2 text-right font-black text-blue-900 dark:text-blue-400 text-sm"><%= @percentage %>% concluído</p>
  </div>

  <div class="mb-10 bg-white dark:bg-gray-900 p-8 rounded-4xl shadow-sm border border-gray-100 dark:border-gray-800 transition-colors">
    <h3 class="text-xs font-black text-gray-400 dark:text-gray-500 uppercase tracking-[0.2em] mb-10 text-center">
      Desempenho por Área de Desenvolvimento
    </h3>
    
    <div class="h-80 w-full">
      <%= bar_chart @stats_data, 
            suffix: "%", 
            colors: ["#3b82f6"], 
            library: { 
              indexAxis: 'y',
              layout: { padding: { bottom: 20 } }, # Adiciona um respiro na base
              scales: {
                x: { 
                  max: 100, 
                  grid: { display: false }, 
                  ticks: { color: '#9ca3af', font: { size: 10 } } 
                },
                y: { 
                  grid: { display: false }, 
                  ticks: { color: '#9ca3af', font: { weight: 'bold', size: 11 } } 
                }
              },
              plugins: { legend: { display: false } }
            } 
      %>
    </div>
    
    <p class="mt-12 text-center text-[11px] text-gray-400 dark:text-gray-600 italic leading-relaxed px-4">
      Este indicador compara as conquistas registradas com o total de marcos previstos para cada domínio.
    </p>
  </div>

  <div class="mb-12 bg-white dark:bg-gray-900 p-6 rounded-3xl shadow-sm border border-yellow-50 dark:border-gray-800 no-print transition-colors">
    <div class="flex items-center gap-2 mb-6">
      <h3 class="text-xs font-bold text-yellow-600 dark:text-yellow-500 uppercase tracking-widest text-center md:text-left">Mural de Conquistas</h3>
      <span class="animate-pulse">🏆</span>
    </div>
    <div class="grid grid-cols-2 md:grid-cols-4 gap-4">
      <% @conquistas.each do |categoria, desbloqueada| %>
        <% 
          icone, titulo = case categoria
            when "motor" then ["🏃", "Atleta Mirim"]
            when "cognitivo" then ["🧩", "Pequeno Gênio"]
            when "linguagem" then ["🗣️", "Tagarela"]
            when "social" then ["🤝", "Amigo de Todos"]
            else ["🌟", "Estrela"]
          end

          medal_classes = desbloqueada ? 
            "bg-gradient-to-br from-yellow-50 to-orange-50 dark:from-yellow-900/30 dark:to-orange-900/30 border-yellow-200 dark:border-yellow-600/50 shadow-md scale-105" : 
            "bg-gray-50 dark:bg-gray-800 border-dashed border-gray-200 dark:border-gray-700 opacity-40 grayscale"
        %>
        <div class="flex flex-col items-center justify-center p-4 rounded-2xl border-2 transition-all duration-700 <%= medal_classes %>">
          <div class="text-3xl mb-2 <%= desbloqueada ? 'animate-bounce-slow' : '' %>"><%= icone %></div>
          <span class="text-[10px] font-black text-center uppercase <%= desbloqueada ? 'text-yellow-800 dark:text-yellow-400' : 'text-gray-400 dark:text-gray-500' %>"><%= titulo %></span>
        </div>
      <% end %>
    </div>
  </div>

  <div class="mb-12 no-print">
    <h3 class="text-xs font-bold text-gray-500 dark:text-gray-400 uppercase tracking-widest mb-4">Linha do Tempo (Meses)</h3>
    <div class="flex space-x-3 overflow-x-auto pb-4 scrollbar-hide timeline-nav">
      <%= link_to "Todos", child_path(@child), class: "shrink-0 px-6 py-2.5 rounded-full font-bold text-sm transition #{ @mes_selecionado.nil? ? 'bg-blue-600 text-white shadow-lg shadow-blue-200 dark:shadow-none' : 'bg-white dark:bg-gray-800 text-gray-500 dark:text-gray-400 border border-gray-200 dark:border-gray-700 hover:bg-gray-50 dark:hover:bg-gray-700' }" %>
      <% @meses_disponiveis.each do |mes| %>
        <%= link_to "#{mes}m", child_path(@child, mes: mes), class: "shrink-0 px-6 py-2.5 rounded-full font-bold text-sm transition #{ @mes_selecionado == mes ? 'bg-blue-600 text-white shadow-lg shadow-blue-200 dark:shadow-none' : 'bg-white dark:bg-gray-800 text-gray-500 dark:text-gray-400 border border-gray-200 dark:border-gray-700 hover:bg-gray-50 dark:hover:bg-gray-700' }" %>
      <% end %>
    </div>
  </div>

  <div class="space-y-16">
    <% if @milestones_exibidas.empty? %>
      <div class="text-center py-16 bg-white dark:bg-gray-900 rounded-3xl border-2 border-dashed border-gray-200 dark:border-gray-800 transition-colors">
        <p class="text-gray-400 dark:text-gray-500 font-medium">Nenhum marco para esta idade específica.</p>
      </div>
    <% else %>
      <% @milestones_exibidas.group_by(&:categoria).each do |categoria, marcos| %>
        <section>
          <h2 class="text-xl font-bold text-gray-800 dark:text-gray-100 border-b-4 border-blue-50 dark:border-gray-800 pb-2 mb-8 capitalize flex items-center gap-2">
            <span class="w-2 h-2 bg-blue-600 dark:bg-blue-500 rounded-full"></span>
            Área: <%= categoria.to_s.humanize %>
          </h2>

          <div class="grid gap-6">
            <% marcos.each do |milestone| %>
              <% 
                progress = @child.progresses.find_by(milestone: milestone) || @child.progresses.build(milestone: milestone) 
                
                # SÓ COLORE SE ESTIVER SALVO NO BANCO
                card_classes = if progress.persisted?
                                 case progress.status
                                 when "adquirido" then "bg-green-50 dark:bg-green-900/10 border-green-200 dark:border-green-800/50 shadow-inner"
                                 when "em_aquisicao" then "bg-yellow-50 dark:bg-yellow-900/10 border-yellow-200 dark:border-yellow-800/50"
                                 when "regressao" then "bg-red-50 dark:bg-red-900/10 border-red-200 dark:border-red-800/50"
                                 else "bg-white dark:bg-gray-900 border-gray-100 dark:border-gray-800 shadow-sm hover:shadow-md"
                                 end
                               else
                                 "bg-white dark:bg-gray-900 border-gray-100 dark:border-gray-800 shadow-sm hover:shadow-md"
                               end
              %>
              
              <div class="milestone-card p-6 rounded-3xl border-2 transition-all duration-300 flex flex-col cursor-pointer <%= card_classes %>" onclick="document.getElementById('modal_milestone_<%= milestone.id %>').showModal()">
                
                <div class="flex justify-between items-start mb-2">
                  <h3 class="font-bold text-gray-900 dark:text-gray-100 text-lg pr-8"><%= milestone.titulo %></h3>
                  
                  <% if progress.persisted? %>
                    <% case progress.status %>
                    <% when "adquirido" %>
                      <span class="bg-green-100 text-green-800 text-xs font-bold px-2.5 py-1 rounded-full dark:bg-green-900/30 dark:text-green-400 absolute top-4 right-4">✔️ Adquirido</span>
                    <% when "em_aquisicao" %>
                      <span class="bg-yellow-100 text-yellow-800 text-xs font-bold px-2.5 py-1 rounded-full dark:bg-yellow-900/30 dark:text-yellow-400 absolute top-4 right-4">⏳ Em Aquisição</span>
                    <% when "regressao" %>
                      <span class="bg-red-100 text-red-800 text-xs font-bold px-2.5 py-1 rounded-full dark:bg-red-900/30 dark:text-red-400 absolute top-4 right-4">🚨 Regressão</span>
                    <% else %>
                      <span class="bg-gray-100 text-gray-800 text-xs font-bold px-2.5 py-1 rounded-full dark:bg-gray-700 dark:text-gray-300 absolute top-4 right-4">Não Avaliado</span>
                    <% end %>
                  <% end %>
                </div>
                
                <%= alerta_acolhedor(milestone, @child) %>
                <p class="text-gray-600 dark:text-gray-400 text-sm leading-relaxed mt-3"><%= milestone.descricao %></p>
                
                <% if progress.persisted? && progress.notes.present? %>
                  <div class="mt-4 p-3 bg-white/60 dark:bg-gray-900/50 rounded-lg border-l-4 border-blue-400 dark:border-blue-600">
                    <p class="text-xs text-gray-700 dark:text-gray-300 italic line-clamp-1 break-word">"<%= progress.notes %>"</p>
                  </div>
                <% end %>

                <span class="inline-block mt-4 text-[10px] font-bold uppercase tracking-wider text-blue-500 dark:text-blue-400 bg-blue-50 dark:bg-blue-900/30 px-3 py-1 rounded-full border border-blue-100 dark:border-blue-800/50 self-start">
                  Janela: <%= milestone.idade_minima_meses %> a <%= milestone.idade_maxima_meses %> meses
                </span>
              </div>

              <dialog id="modal_milestone_<%= milestone.id %>" class="backdrop:bg-gray-900/80 p-0 rounded-3xl shadow-2xl bg-white dark:bg-gray-800 max-w-lg w-full mx-auto my-auto fixed open:animate-in open:fade-in open:zoom-in-95 duration-200">
                <div class="p-8">
                  <div class="flex justify-between items-center mb-6">
                    <h3 class="text-xl font-bold text-gray-900 dark:text-white">Avaliar Marco</h3>
                    <form method="dialog">
                      <button class="text-gray-400 hover:text-gray-600 dark:hover:text-gray-200 transition-colors">
                        <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"></path></svg>
                      </button>
                    </form>
                  </div>

                  <div class="mb-6 p-4 bg-blue-50 dark:bg-blue-900/20 rounded-xl">
                    <h4 class="font-bold text-blue-900 dark:text-blue-400 mb-1"><%= milestone.titulo %></h4>
                    <p class="text-sm text-blue-800 dark:text-blue-300"><%= milestone.descricao %></p>
                  </div>

                  <% if progress.persisted? && progress.notes.present? %>
                    <div class="mb-6 p-4 bg-blue-50/50 dark:bg-blue-900/10 border border-blue-100 dark:border-blue-800/50 rounded-xl max-h-32 overflow-y-auto">
                      <span class="text-[10px] font-black uppercase tracking-wider text-blue-500 mb-2 block">Sua última observação:</span>
                      <p class="text-sm text-gray-700 dark:text-gray-300 italic wrap-break-word whitespace-pre-wrap">"<%= progress.notes %>"</p>
                    </div>
                  <% end %>

                  <%= form_with(model: progress, url: child_progresses_path(@child), method: :post, data: { turbo: false }, class: "space-y-6") do |f| %>
                    <%= f.hidden_field :milestone_id, value: milestone.id %>
                    
                    <div>
                      <label class="block text-sm font-bold text-gray-700 dark:text-gray-300 mb-3">Status do Desenvolvimento:</label>
                     <div class="grid grid-cols-2 gap-3">
                        
                        <label class="relative flex items-center p-3 border border-gray-200 dark:border-gray-700 rounded-xl cursor-pointer hover:bg-gray-50 dark:hover:bg-gray-700 transition-colors has-checked:bg-gray-100 has-checked:border-gray-500 dark:has-checked:bg-gray-600">
                          <%= f.radio_button :status, "nao_avaliado", class: "peer sr-only" %>
                          <div class="flex-1">
                            <div class="font-bold text-gray-900 dark:text-white text-sm">Não Avaliado</div>
                          </div>
                        </label>

                        <label class="relative flex items-center p-3 border border-yellow-200 dark:border-yellow-900/50 rounded-xl cursor-pointer hover:bg-yellow-50 dark:hover:bg-yellow-900/20 transition-colors has-checked:bg-yellow-50 has-checked:border-yellow-500 dark:has-checked:bg-yellow-900/40">
                          <%= f.radio_button :status, "em_aquisicao", class: "peer sr-only" %>
                          <div class="flex-1">
                            <div class="font-bold text-yellow-800 dark:text-yellow-400 text-sm">⏳ Em Aquisição</div>
                            <div class="text-[10px] text-yellow-600 dark:text-yellow-500 mt-0.5">Tenta ou faz com ajuda</div>
                          </div>
                        </label>

                        <label class="relative flex items-center p-3 border border-green-200 dark:border-green-900/50 rounded-xl cursor-pointer hover:bg-green-50 dark:hover:bg-green-900/20 transition-colors has-checked:bg-green-50 has-checked:border-green-500 dark:has-checked:bg-green-900/40">
                          <%= f.radio_button :status, "adquirido", class: "peer sr-only" %>
                          <div class="flex-1">
                            <div class="font-bold text-green-800 dark:text-green-400 text-sm">✔️ Adquirido</div>
                            <div class="text-[10px] text-green-600 dark:text-green-500 mt-0.5">Faz sozinho e sempre</div>
                          </div>
                        </label>

                        <label class="relative flex items-center p-3 border border-red-200 dark:border-red-900/50 rounded-xl cursor-pointer hover:bg-red-50 dark:hover:bg-red-900/20 transition-colors has-checked:bg-red-50 has-checked:border-red-500 dark:has-checked:bg-red-900/40">
                          <%= f.radio_button :status, "regressao", class: "peer sr-only" %>
                          <div class="flex-1">
                            <div class="font-bold text-red-800 dark:text-red-400 text-sm">🚨 Regressão</div>
                            <div class="text-[10px] text-red-600 dark:text-red-500 mt-0.5">Fazia, mas parou</div>
                          </div>
                        </label>

                      </div>
                    </div>

                    <div>
                      <div class="flex justify-between items-end mb-2">
                        <label class="block text-sm font-bold text-gray-700 dark:text-gray-300">Atualizar Diário (Opcional):</label>
                        <span class="text-[10px] text-gray-400 dark:text-gray-500 font-medium">Máx 250 caracteres</span>
                      </div>
                      <%= f.text_area :notes, rows: 3, maxlength: 250, placeholder: "Escreva uma observação para o pediatra...", class: "w-full px-4 py-3 rounded-xl border border-gray-300 dark:border-gray-600 bg-white dark:bg-gray-700 text-gray-900 dark:text-white placeholder-gray-400 focus:ring-2 focus:ring-blue-500 focus:border-transparent transition-all resize-none text-sm" %>
                    </div>

                    <div class="pt-4 border-t border-gray-100 dark:border-gray-700 flex justify-end gap-3">
                      <form method="dialog" class="inline">
                        <button type="submit" class="px-6 py-2.5 text-sm font-bold text-gray-600 dark:text-gray-300 hover:bg-gray-100 dark:hover:bg-gray-700 rounded-xl transition-colors cursor-pointer">Cancelar</button>
                      </form>
                      <%= f.submit "Salvar Avaliação", class: "px-6 py-2.5 text-sm font-bold text-white bg-blue-600 hover:bg-blue-700 dark:bg-blue-500 dark:hover:bg-blue-600 rounded-xl shadow-lg shadow-blue-200 dark:shadow-none cursor-pointer transition-all hover:scale-105" %>
                    </div>
                  <% end %>
                </div>
              </dialog>

            <% end %>
          </div>
        </section>
      <% end %>
    <% end %>
  </div>

  <footer class="mt-20 border-t border-gray-200 dark:border-gray-800 pt-10 text-center no-print transition-colors">
    <div class="max-w-2xl mx-auto p-8 bg-blue-900 dark:bg-gray-800 rounded-3xl text-white shadow-xl shadow-blue-100 dark:shadow-none transition-colors">
      <h4 class="font-bold text-xl mb-3 text-blue-100 dark:text-blue-300">Dúvidas sobre o desenvolvimento?</h4>
      <p class="text-sm opacity-90 mb-6 leading-relaxed">
        Este sistema é uma ferramenta de apoio. Se notar algo diferente, procure o pediatra ou a unidade de saúde.
      </p>
      <%= link_to "Ver Rede de Apoio e Orientações", support_path, class: "inline-block bg-white dark:bg-gray-900 text-blue-900 dark:text-blue-400 px-8 py-3 rounded-full font-bold hover:bg-blue-50 dark:hover:bg-black transition" %>
    </div>
  </footer>
</div>