<div class="max-w-4xl mx-auto mt-6 md:mt-10 px-4 pb-20">
  
  <style>
    @media print {
      nav, footer, .no-print, button, form, .timeline-nav { display: none !important; }
      body { background-color: white !important; }
      .bg-blue-600 { background-color: #2563eb !important; -webkit-print-color-adjust: exact; print-color-adjust: exact; }
      .bg-green-50 { background-color: #f0fdf4 !important; -webkit-print-color-adjust: exact; print-color-adjust: exact; }
      section, .milestone-card { page-break-inside: avoid; }
      .shadow-sm, .shadow-xl { box-shadow: none !important; border: 1px solid #e5e7eb !important; }
    }
  </style>

  <nav class="mb-8 no-print">
    <%= link_to "← Voltar para Meus Pequenos", children_path, class: "text-blue-600 hover:underline text-sm font-medium" %>
  </nav>

  <div class="no-print flex justify-end mb-6">
    <button onclick="window.print()" class="flex items-center bg-gray-800 text-white px-5 py-2.5 rounded-xl text-sm font-bold hover:bg-black transition shadow-lg shadow-gray-200 cursor-pointer">
      <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 mr-2" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 17h2a2 2 0 002-2v-4a2 2 0 00-2-2H5a2 2 0 00-2 2v4a2 2 0 002 2h2m2 4h6a2 2 0 002-2v-4a2 2 0 00-2-2H9a2 2 0 00-2 2v4a2 2 0 002 2zm8-12V5a2 2 0 00-2-2H9a2 2 0 00-2 2v4h10z" /></svg>
      Gerar Relatório Médico
    </button>
  </div>

  <header class="mb-10 text-center">
    <h1 class="text-3xl md:text-4xl font-extrabold text-blue-900 mb-2">Marcos de <%= @child.nome %></h1>
    <p class="text-gray-600">
      Perfil: <span class="font-semibold"><%= @child.tipo_desenvolvimento.humanize %></span> • 
      Idade atual: <span class="font-semibold text-blue-700"><%= @child.idade_em_meses %> meses</span>
    </p>
  </header>

  <div class="mb-10 bg-white p-6 rounded-3xl shadow-sm border border-blue-50">
    <div class="flex justify-between items-end mb-3">
      <h3 class="text-xs font-bold text-blue-800 uppercase tracking-widest">Progresso Geral</h3>
      <span class="text-xs font-bold text-gray-500"><%= @achieved_milestones %> de <%= @total_milestones %> concluídos</span>
    </div>
    <div class="w-full bg-gray-100 rounded-full h-4 overflow-hidden">
      <div class="bg-blue-600 h-full transition-all duration-1000" style="width: <%= @percentage %>%"></div>
    </div>
    <p class="mt-2 text-right font-black text-blue-900 text-sm"><%= @percentage %>% concluído</p>
  </div>

  <div class="mb-12 bg-white p-6 rounded-3xl shadow-sm border border-yellow-50 no-print">
    <div class="flex items-center gap-2 mb-6">
      <h3 class="text-xs font-bold text-yellow-600 uppercase tracking-widest text-center md:text-left">Mural de Conquistas</h3>
      <span class="animate-pulse">🏆</span>
    </div>
    
    <div class="grid grid-cols-2 md:grid-cols-4 gap-4">
      <% @conquistas.each do |categoria, desbloqueada| %>
        <% 
          icone, titulo = case categoria
            when "motor" then ["🏃", "Atleta Mirim"]
            when "cognitivo" then ["🧩", "Pequeno Gênio"]
            when "linguagem" then ["🗣️", "Tagarela"]
            when "social" then ["🤝", "Amigo de Todos"]
            else ["🌟", "Estrela"]
          end

          # Lógica de classes extraída para evitar conflitos
          medal_classes = desbloqueada ? 
            "bg-gradient-to-br from-yellow-50 to-orange-50 border-yellow-200 shadow-md scale-105" : 
            "bg-gray-50 border-dashed border-gray-200 opacity-40 grayscale"
        %>
        <div class="flex flex-col items-center justify-center p-4 rounded-2xl border-2 transition-all duration-700 <%= medal_classes %>">
          <div class="text-3xl mb-2 <%= desbloqueada ? 'animate-bounce-slow' : '' %>"><%= icone %></div>
          <span class="text-[10px] font-black text-center uppercase <%= desbloqueada ? 'text-yellow-800' : 'text-gray-400' %>"><%= titulo %></span>
        </div>
      <% end %>
    </div>
  </div>

  <div class="mb-12 no-print">
    <h3 class="text-xs font-bold text-gray-500 uppercase tracking-widest mb-4">Linha do Tempo (Meses)</h3>
    <div class="flex space-x-3 overflow-x-auto pb-4 scrollbar-hide timeline-nav">
      <%= link_to "Todos", child_path(@child), class: "flex-shrink-0 px-6 py-2.5 rounded-full font-bold text-sm transition #{ @mes_selecionado.nil? ? 'bg-blue-600 text-white shadow-lg' : 'bg-white text-gray-500 border border-gray-200 hover:bg-gray-50' }" %>
      <% @meses_disponiveis.each do |mes| %>
        <%= link_to "#{mes}m", child_path(@child, mes: mes), class: "flex-shrink-0 px-6 py-2.5 rounded-full font-bold text-sm transition #{ @mes_selecionado == mes ? 'bg-blue-600 text-white shadow-lg' : 'bg-white text-gray-500 border border-gray-200 hover:bg-gray-50' }" %>
      <% end %>
    </div>
  </div>

  <div class="space-y-16">
    <% if @milestones_exibidas.empty? %>
      <div class="text-center py-16 bg-white rounded-3xl border-2 border-dashed border-gray-200">
        <p class="text-gray-400 font-medium">Nenhum marco para esta idade específica.</p>
      </div>
    <% else %>
      <% @milestones_exibidas.group_by(&:categoria).each do |categoria, marcos| %>
        <section>
          <h2 class="text-xl font-bold text-gray-800 border-b-4 border-blue-50 pb-2 mb-8 capitalize flex items-center gap-2">
            <span class="w-2 h-2 bg-blue-600 rounded-full"></span>
            Área: <%= categoria.to_s.humanize %>
          </h2>

          <div class="grid gap-6">
            <% marcos.each do |milestone| %>
              <% 
                progress = @child.progresses.find_by(milestone: milestone) 
                
                # Lógica de classes extraída para evitar conflitos
                card_classes = progress ? 
                  "bg-green-50 border-green-200 shadow-inner" : 
                  "bg-white border-gray-100 shadow-sm"
              %>
              <div class="milestone-card p-6 rounded-3xl border-2 transition-all duration-300 flex items-start justify-between <%= card_classes %>">
                <div class="flex-1">
                  <h3 class="font-bold text-gray-900 text-lg mb-2"><%= milestone.titulo %></h3>
                  <%= alerta_acolhedor(milestone, @child) %>
                  <p class="text-gray-600 text-sm leading-relaxed mt-3"><%= milestone.descricao %></p>
                  <span class="inline-block mt-4 text-[10px] font-bold uppercase tracking-wider text-blue-500 bg-blue-50 px-3 py-1 rounded-full border border-blue-100">
                    Janela: <%= milestone.idade_minima_meses %> a <%= milestone.idade_maxima_meses %> meses
                  </span>
                </div>
                
                <div class="ml-4 no-print">
                  <%= button_to child_progresses_path(@child, milestone_id: milestone.id, mes: @mes_selecionado), 
                                method: :post, 
                                class: "group p-3 rounded-2xl border-2 transition-all duration-300 #{progress ? 'bg-green-500 border-green-500 text-white shadow-lg' : 'border-gray-200 text-gray-300 hover:border-green-500 hover:text-green-500'}" do %>
                    <svg xmlns="http://www.w3.org/2000/svg" class="h-8 w-8 transition-transform group-hover:scale-110" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
                    </svg>
                  <% end %>
                </div>
              </div>
            <% end %>
          </div>
        </section>
      <% end %>
    <% end %>
  </div>

  <footer class="mt-20 border-t border-gray-200 pt-10 text-center no-print">
    <div class="max-w-2xl mx-auto p-8 bg-blue-900 rounded-3xl text-white shadow-xl shadow-blue-100">
      <h4 class="font-bold text-xl mb-3 text-blue-100">Dúvidas sobre o desenvolvimento?</h4>
      <p class="text-sm opacity-90 mb-6 leading-relaxed">
        Este sistema é uma ferramenta de apoio. Se notar algo diferente, procure o pediatra ou a unidade de saúde.
      </p>
      <%= link_to "Ver Rede de Apoio e Orientações", support_path, class: "inline-block bg-white text-blue-900 px-8 py-3 rounded-full font-bold hover:bg-blue-50 transition" %>
    </div>
  </footer>
</div>