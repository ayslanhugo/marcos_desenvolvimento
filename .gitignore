# See https://help.github.com/articles/ignoring-files for more about ignoring files.

# Ignore bundler config.
/.bundle

# Ignore all environment files (onde ficam senhas e APIs)
.env
.env.*
/.env*

# Ignore all logfiles and tempfiles.
/log/*
/tmp/*
!/log/.keep
!/tmp/.keep

# Ignore pidfiles, but keep the directory.
/tmp/pids/*
!/tmp/pids/
!/tmp/pids/.keep

# Ignore storage and uploaded files locally (fotos, pdfs gerados, etc)
/storage/*
!/storage/.keep
/tmp/storage/*
!/tmp/storage/
!/tmp/storage/.keep
/public/system/

# Ignore assets/builds
/public/assets
/app/assets/builds/*
!/app/assets/builds/.keep
/node_modules

# Ignore bancos de dados locais
/db/*.sqlite3
/db/*.sqlite3-*

# Ignore a chave mestra de criptografia do Rails (MUITO IMPORTANTE)
/config/master.key
/config/credentials/*.key